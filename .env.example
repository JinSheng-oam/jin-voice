# Docker Compose interpolation for the source-tree coturn service.
# Keep it consistent with client/.env VITE_TURN_USERNAME and VITE_TURN_PASSWORD.
TURN_USER=replace-with-turn-username:replace-with-turn-password
VITE_TURN_SERVER=turn.example.com
VITE_TURN_USERNAME=replace-with-turn-username
VITE_TURN_PASSWORD=replace-with-turn-password
