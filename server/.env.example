PORT=5000
HOST=0.0.0.0
DATABASE_URL="file:../data/dev.db"

# Local development uses 127.0.0.1. Production must use a client-reachable IP.
MEDIASOUP_LISTEN_IP=0.0.0.0
MEDIASOUP_ANNOUNCED_IP=127.0.0.1

# Restrict this to the public web origin in production. Separate multiple
# trusted origins with commas.
CORS_ORIGIN=https://voice.example.com

# Optional bootstrap administrator. Use a unique strong password.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-password
ADMIN_DISPLAY_NAME=Administrator
