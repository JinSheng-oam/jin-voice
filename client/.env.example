# Leave VITE_SERVER_URL empty when the web client is served by the API origin.
# VITE_SERVER_URL=http://127.0.0.1:5000

# TURN credentials are embedded in the frontend bundle. Use limited,
# deployment-specific credentials and rotate them regularly.
VITE_TURN_SERVER=turn.example.com
VITE_TURN_USERNAME=replace-with-turn-username
VITE_TURN_PASSWORD=replace-with-turn-password
